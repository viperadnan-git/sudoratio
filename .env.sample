# Copy to `.env` next to docker-compose.yml (or wherever you run sudoratio-server from).
# Uncommented values override built-in defaults; CLI flags still win over both.

# ─── Auth (required) ──────────────────────────────────────────────────────────
# Single-password auth. Clients hex-encode this and send `Authorization: Bearer <hex>`.
SUDORATIO_PASSWORD=changeme

# ─── HTTP API ─────────────────────────────────────────────────────────────────
# SUDORATIO_LISTEN=0.0.0.0:8787
# Tower per-process concurrency cap (additional requests queue).
# SUDORATIO_HTTP_API_CONCURRENCY=16384

# ─── Persistence ──────────────────────────────────────────────────────────────
# Created automatically. Holds `config.json`, `session.sqlite3`, and `clients/*.toml`.
# SUDORATIO_CONFIG_DIR=.sudoratio

# ─── BT peer protocol ─────────────────────────────────────────────────────────
# Empty disables the listener. `0.0.0.0:0` lets the kernel pick an ephemeral port.
# SUDORATIO_PEER_LISTEN=0.0.0.0:0
# Fallback `port=` value if the BT listener can't bind. Normally we announce the bound port.
# SUDORATIO_ANNOUNCE_PORT=51413

# ─── Simulated bandwidth (decimal KB/s) ───────────────────────────────────────
# Per-torrent cap is uniformly sampled inside `[min, max]` after each announce,
# with ±10% tick-level jitter applied each bandwidth tick.
# SUDORATIO_MIN_UPLOAD_SPEED=150
# SUDORATIO_MAX_UPLOAD_SPEED=200
# SUDORATIO_MIN_DOWNLOAD_SPEED=800
# SUDORATIO_MAX_DOWNLOAD_SPEED=1200
# SUDORATIO_BANDWIDTH_TICK_MS=5000

# ─── Seeding policy ───────────────────────────────────────────────────────────
# SUDORATIO_MAX_ACTIVE_TORRENTS=5
# Negative value disables the cap entirely.
# SUDORATIO_UPLOAD_RATIO_TARGET=-1
# Auto-pause torrents whose swarm has had zero leechers for the grace period.
# SUDORATIO_PAUSE_TORRENT_WITH_ZERO_LEECHERS=false
# Grace window in seconds before zero-leecher pause fires (default 3h).
# SUDORATIO_PAUSE_TORRENT_WITH_ZERO_LEECHERS_GRACE=10800

# ─── Tracker HTTP transport (reqwest) ─────────────────────────────────────────
# SUDORATIO_HTTP_TRACKER_CONNECT_TIMEOUT_SECS=10
# SUDORATIO_HTTP_TRACKER_REQUEST_TIMEOUT_SECS=5
# SUDORATIO_HTTP_TRACKER_MAX_IDLE_PER_HOST=100
# SUDORATIO_HTTP_TRACKER_MAX_REDIRECTS=10
# SUDORATIO_HTTP_TCP_KEEPALIVE_SECS=30
# SUDORATIO_HTTP_POOL_IDLE_TIMEOUT_SECS=60
# Cap on simultaneous in-flight tracker announces engine-wide (`0` = unlimited).
# SUDORATIO_MAX_CONCURRENT_ANNOUNCES=16

# ─── Logging (tracing-subscriber EnvFilter syntax) ────────────────────────────
# RUST_LOG=sudoratio_server=info,sudoratio_core=info,tower_http=info

# ─── Docker compose only (ignored when running the binary directly) ───────────
# Host port mapped to the container's 8787.
# SUDORATIO_PORT=8787
# Image override; default pulls from Docker Hub. Set to ghcr.io/... for GHCR.
# SUDORATIO_IMAGE=ghcr.io/viperadnan-git/sudoratio:latest
# Compose-only convenience var; merged into RUST_LOG inside the container.
# SUDORATIO_LOG=sudoratio_server=info,sudoratio_core=info,tower_http=info
